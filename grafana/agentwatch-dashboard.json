{
  "__inputs": [
    {
      "name": "DS_AGENTWATCH",
      "label": "AgentWatch PostgreSQL",
      "description": "PostgreSQL database used by AgentWatch (configure connection during import)",
      "type": "datasource",
      "pluginId": "postgres",
      "pluginName": "PostgreSQL"
    }
  ],
  "__elements": {},
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "postgres",
      "name": "PostgreSQL",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "barchart",
      "name": "Bar chart",
      "version": ""
    },
    {
      "type": "panel",
      "id": "gauge",
      "name": "Gauge",
      "version": ""
    },
    {
      "type": "panel",
      "id": "table",
      "name": "Table",
      "version": ""
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "AgentWatch observability - session activity, safety events, agent confidence, and cost tracking",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {
        "type": "postgres",
        "uid": "${DS_AGENTWATCH}"
      },
      "description": "Number of agent sessions started per hour over the selected time range.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "Sessions",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 12,
            "gradientMode": "none",
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            },
            "insertNulls": false,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 4,
            "scaleDistribution": {
              "type": "linear"
            },
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": {
              "group": "A",
              "mode": "none"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 80
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 16,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "legend": {
          "calcs": [
            "sum",
            "max"
          ],
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "${DS_AGENTWATCH}"
          },
          "editorMode": "code",
          "format": "time_series",
          "hide": false,
          "rawQuery": true,
          "rawSql": "SELECT\n  date_trunc('hour', started_at) AS time,\n  COUNT(*) FILTER (WHERE status NOT IN ('failure', 'blocked')) AS \"Successful\",\n  COUNT(*) FILTER (WHERE status = 'failure') AS \"Failed\",\n  COUNT(*) FILTER (WHERE status = 'blocked') AS \"Blocked\"\nFROM agent_sessions\nWHERE $__timeFilter(started_at)\n  AND framework IN (${framework:sqlstring})\n  AND agent_id IN (${agent_id:sqlstring})\nGROUP BY 1\nORDER BY 1",
          "refId": "A"
        }
      ],
      "title": "Total Sessions Over Time",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "postgres",
        "uid": "${DS_AGENTWATCH}"
      },
      "description": "Percentage of sessions that ended in a failure or blocked state within the selected time range.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 10
              },
              {
                "color": "orange",
                "value": 25
              },
              {
                "color": "red",
                "value": 50
              }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "${DS_AGENTWATCH}"
          },
          "editorMode": "code",
          "format": "table",
          "hide": false,
          "rawQuery": true,
          "rawSql": "SELECT\n  ROUND(\n    100.0 * COUNT(*) FILTER (WHERE status IN ('failure', 'blocked'))\n    / NULLIF(COUNT(*), 0),\n  2) AS \"Failed Session Rate\"\nFROM agent_sessions\nWHERE $__timeFilter(started_at)\n  AND framework IN (${framework:sqlstring})\n  AND agent_id IN (${agent_id:sqlstring})",
          "refId": "A"
        }
      ],
      "title": "Failed Session Rate",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "postgres",
        "uid": "${DS_AGENTWATCH}"
      },
      "description": "Number of events blocked by the safety engine per hour, broken down by risk level.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "Blocks",
            "axisPlacement": "auto",
            "fillOpacity": 80,
            "gradientMode": "none",
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            },
            "lineWidth": 1,
            "scaleDistribution": {
              "type": "linear"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 80
              }
            ]
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "critical"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "high"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "orange",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "medium"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "yellow",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "low"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "blue",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 3,
      "options": {
        "barRadius": 0.1,
        "barWidth": 0.6,
        "fullHighlight": false,
        "groupWidth": 0.7,
        "legend": {
          "calcs": [
            "sum"
          ],
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "orientation": "auto",
        "stacking": "normal",
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "xTickLabelRotation": 0,
        "xTickLabelSpacing": 100
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "${DS_AGENTWATCH}"
          },
          "editorMode": "code",
          "format": "time_series",
          "hide": false,
          "rawQuery": true,
          "rawSql": "SELECT\n  date_trunc('hour', timestamp) AS time,\n  COUNT(*) FILTER (WHERE risk_level = 'critical') AS \"critical\",\n  COUNT(*) FILTER (WHERE risk_level = 'high') AS \"high\",\n  COUNT(*) FILTER (WHERE risk_level = 'medium') AS \"medium\",\n  COUNT(*) FILTER (WHERE risk_level = 'low') AS \"low\"\nFROM agent_events\nWHERE safety_blocked = true\n  AND $__timeFilter(timestamp)\n  AND framework IN (${framework:sqlstring})\n  AND agent_id IN (${agent_id:sqlstring})\nGROUP BY 1\nORDER BY 1",
          "refId": "A"
        }
      ],
      "title": "Safety Blocks Per Hour",
      "type": "barchart"
    },
    {
      "datasource": {
        "type": "postgres",
        "uid": "${DS_AGENTWATCH}"
      },
      "description": "Average confidence score across all agent reasoning steps in the selected time range. Scores below 0.5 indicate elevated hallucination or goal-drift risk.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "decimals": 2,
          "mappings": [],
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.4
              },
              {
                "color": "yellow",
                "value": 0.6
              },
              {
                "color": "green",
                "value": 0.8
              }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 4,
      "options": {
        "minVizHeight": 75,
        "minVizWidth": 75,
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "mean"
          ],
          "fields": "",
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "sizing": "auto"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "${DS_AGENTWATCH}"
          },
          "editorMode": "code",
          "format": "table",
          "hide": false,
          "rawQuery": true,
          "rawSql": "SELECT\n  AVG(confidence_score) AS \"Average Confidence\"\nFROM agent_events\nWHERE confidence_score IS NOT NULL\n  AND $__timeFilter(timestamp)\n  AND framework IN (${framework:sqlstring})\n  AND agent_id IN (${agent_id:sqlstring})",
          "refId": "A"
        }
      ],
      "title": "Average Confidence Score",
      "type": "gauge"
    },
    {
      "datasource": {
        "type": "postgres",
        "uid": "${DS_AGENTWATCH}"
      },
      "description": "Estimated USD cost and token usage per session, ordered by highest cost. Useful for identifying runaway agents.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 80
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "cost_usd"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Cost (USD)"
              },
              {
                "id": "unit",
                "value": "currencyUSD"
              },
              {
                "id": "decimals",
                "value": 6
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "mode": "gradient",
                  "type": "color-background"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "yellow",
                      "value": 0.01
                    },
                    {
                      "color": "orange",
                      "value": 0.1
                    },
                    {
                      "color": "red",
                      "value": 1
                    }
                  ]
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "total_tokens"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Total Tokens"
              },
              {
                "id": "unit",
                "value": "short"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "status"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "options": {
                      "failure": {
                        "color": "red",
                        "index": 0,
                        "text": "failure"
                      }
                    },
                    "type": "value"
                  },
                  {
                    "options": {
                      "success": {
                        "color": "green",
                        "index": 1,
                        "text": "success"
                      }
                    },
                    "type": "value"
                  },
                  {
                    "options": {
                      "blocked": {
                        "color": "orange",
                        "index": 2,
                        "text": "blocked"
                      }
                    },
                    "type": "value"
                  },
                  {
                    "options": {
                      "running": {
                        "color": "blue",
                        "index": 3,
                        "text": "running"
                      }
                    },
                    "type": "value"
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "started_at"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Started"
              },
              {
                "id": "unit",
                "value": "dateTimeAsLocal"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "agent_name"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Agent"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "framework"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Framework"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "session_id"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Session ID"
              },
              {
                "id": "custom.width",
                "value": 280
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "id": 5,
      "options": {
        "cellHeight": "sm",
        "footer": {
          "countRows": false,
          "fields": [
            "cost_usd",
            "total_tokens"
          ],
          "reducer": [
            "sum"
          ],
          "show": true
        },
        "showHeader": true,
        "sortBy": [
          {
            "desc": true,
            "displayName": "Cost (USD)"
          }
        ]
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "${DS_AGENTWATCH}"
          },
          "editorMode": "code",
          "format": "table",
          "hide": false,
          "rawQuery": true,
          "rawSql": "SELECT\n  session_id,\n  COALESCE(agent_name, agent_id) AS agent_name,\n  framework,\n  status,\n  total_tokens,\n  ROUND(estimated_cost_usd::numeric, 6) AS cost_usd,\n  started_at\nFROM agent_sessions\nWHERE $__timeFilter(started_at)\n  AND framework IN (${framework:sqlstring})\n  AND agent_id IN (${agent_id:sqlstring})\nORDER BY estimated_cost_usd DESC\nLIMIT 25",
          "refId": "A"
        }
      ],
      "title": "Cost Per Session",
      "type": "table"
    },
    {
      "datasource": {
        "type": "postgres",
        "uid": "${DS_AGENTWATCH}"
      },
      "description": "Most frequently blocked tool calls and commands, ranked by occurrence. Use this to tune safety policies or identify misbehaving agents.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 80
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "block_count"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Blocks"
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "mode": "gradient",
                  "type": "color-background"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "blue",
                      "value": null
                    },
                    {
                      "color": "yellow",
                      "value": 5
                    },
                    {
                      "color": "orange",
                      "value": 20
                    },
                    {
                      "color": "red",
                      "value": 50
                    }
                  ]
                }
              },
              {
                "id": "custom.width",
                "value": 80
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "risk_level"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Risk Level"
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "options": {
                      "critical": {
                        "color": "red",
                        "index": 0,
                        "text": "CRITICAL"
                      }
                    },
                    "type": "value"
                  },
                  {
                    "options": {
                      "high": {
                        "color": "orange",
                        "index": 1,
                        "text": "HIGH"
                      }
                    },
                    "type": "value"
                  },
                  {
                    "options": {
                      "medium": {
                        "color": "yellow",
                        "index": 2,
                        "text": "MEDIUM"
                      }
                    },
                    "type": "value"
                  },
                  {
                    "options": {
                      "low": {
                        "color": "blue",
                        "index": 3,
                        "text": "LOW"
                      }
                    },
                    "type": "value"
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              },
              {
                "id": "custom.width",
                "value": 100
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "tool_name"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Tool"
              },
              {
                "id": "custom.width",
                "value": 160
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "tool_raw_command"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Command"
              },
              {
                "id": "custom.inspect",
                "value": true
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "id": 6,
      "options": {
        "cellHeight": "sm",
        "footer": {
          "show": false
        },
        "showHeader": true,
        "sortBy": [
          {
            "desc": true,
            "displayName": "Blocks"
          }
        ]
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "${DS_AGENTWATCH}"
          },
          "editorMode": "code",
          "format": "table",
          "hide": false,
          "rawQuery": true,
          "rawSql": "SELECT\n  COALESCE(tool_name, '(unknown)') AS tool_name,\n  COALESCE(tool_raw_command, tool_arguments::text, '(no command)') AS tool_raw_command,\n  risk_level,\n  COUNT(*) AS block_count\nFROM agent_events\nWHERE safety_blocked = true\n  AND $__timeFilter(timestamp)\n  AND framework IN (${framework:sqlstring})\n  AND agent_id IN (${agent_id:sqlstring})\nGROUP BY 1, 2, 3\nORDER BY block_count DESC\nLIMIT 25",
          "refId": "A"
        }
      ],
      "title": "Top Blocked Commands",
      "type": "table"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": [
    "agentwatch",
    "ai-agents",
    "observability",
    "safety"
  ],
  "templating": {
    "list": [
      {
        "current": {
          "selected": false,
          "text": "All",
          "value": "$__all"
        },
        "datasource": {
          "type": "postgres",
          "uid": "${DS_AGENTWATCH}"
        },
        "definition": "SELECT DISTINCT framework FROM agent_sessions ORDER BY 1",
        "hide": 0,
        "includeAll": true,
        "label": "Framework",
        "multi": true,
        "name": "framework",
        "options": [],
        "query": "SELECT DISTINCT framework FROM agent_sessions ORDER BY 1",
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query"
      },
      {
        "current": {
          "selected": false,
          "text": "All",
          "value": "$__all"
        },
        "datasource": {
          "type": "postgres",
          "uid": "${DS_AGENTWATCH}"
