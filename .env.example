# AgentWatch environment configuration
# Copy this file to .env and fill in the values for your environment.
# Never commit .env to version control.

# -------------------------------------------------------
# CORS
# -------------------------------------------------------

# Comma-separated list of allowed frontend origins.
# Defaults to http://localhost:3000 for local development.
# In production set this to the exact URL of your deployed frontend.
ALLOWED_ORIGINS=http://localhost:3000

# -------------------------------------------------------
# Database
# -------------------------------------------------------

# Full asyncpg connection string (takes precedence over individual DB_* vars).
# For a local Docker stack this matches docker-compose.yml:
DATABASE_URL=postgresql+asyncpg://agentwatch:your_password_here@localhost:5432/agentwatch

# Individual connection parameters (used when DATABASE_URL is not set).
DB_HOST=localhost
DB_PORT=5432
DB_NAME=agentwatch
DB_USER=agentwatch
# DB_PASSWORD must be set explicitly. There is no default.
DB_PASSWORD=your_password_here

# -------------------------------------------------------
# Application
# -------------------------------------------------------

AGENTWATCH_ENV=development

# -------------------------------------------------------
# Optional integrations
# -------------------------------------------------------

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1

# Alerting webhooks (leave blank to disable)
SLACK_WEBHOOK_URL=
PAGERDUTY_WEBHOOK_URL=
